generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// MULTI-TENANT CORE
// ============================================================

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan                     String   @default("free")
  customDailyTokenLimit    Int?
  customWeeklyTokenLimit   Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  onboardingCompletedAt    DateTime?

  // Workspace settings
  industry                 String?
  defaultTimezone          String?
  notifyImportCompleted    Boolean  @default(true)
  notifyImportFailed       Boolean  @default(true)
  notifyRuleUpdated        Boolean  @default(false)
  notifyBillingIssue       Boolean  @default(true)
  notifyProductUpdates     Boolean  @default(false)

  members                  OrgMember[]
  dataSources              DataSource[]
  mappingTemplates         MappingTemplate[]
  flaggedColumns           FlaggedColumn[]
  products                 Product[]
  suppliers                Supplier[]
  locations                Location[]
  inventory                InventoryItem[]
  orders                   Order[]
  forecastEntries          ForecastEntry[]
  mpsEntries               MpsEntry[]
  workOrders               WorkOrder[]
  routings                 Routing[]
  workCenters              WorkCenter[]
  brainRules               BrainRule[]
  appInstances             AppInstance[]
  // ODE
  connectors               Connector[]
  operationalRelationships OperationalRelationship[]
  operationalEvents        OperationalEvent[]
  // Normalization
  entityResolutionLogs     EntityResolutionLog[]
  modelCompletenessReport  ModelCompletenessReport?
  modelFreshness           ModelFreshness[]
  logicParams              LogicParam[]
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Profile fields
  jobTitle      String?
  companyName   String?
  industry      String?
  primaryFocus  String[]
  timezone      String?
  language      String?   @default("en")
  aiAnswerStyle String?   // "concise" | "detailed"

  memberships OrgMember[]
  accounts    Account[]
  sessions    Session[]
  otpCodes    OtpCode[]
}

model OrgMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           OrgRole  @default(MEMBER)
  permissions    Json?    // custom per-user feature flags; null = use role defaults
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

// NextAuth.js models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model OtpCode {
  id        String   @id @default(cuid())
  userId    String
  code      String
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================================
// LAYER 1 — OPERATIONAL DATA LAYER
// ============================================================

model DataSource {
  id             String         @id @default(cuid())
  organizationId String
  name           String
  type           DataSourceType
  originalName   String
  fileSize       Int
  status         ImportStatus   @default(PENDING)
  rowCount       Int?
  importedRows   Int?
  errorMessage   String?
  mappingConfig  Json?
  rawHeaders     String[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  normalizationStatus String @default("pending") // "pending" | "complete" | "failed"
  dataQualityScores   Json? // { Product: 87, Supplier: 62, InventoryItem: 45 }

  // Snapshot import tracking
  snapshotDeactivatedCount Int?      // How many records were deactivated by this import
  snapshotCompletedAt      DateTime? // When deactivation ran (for 24h undo window)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// Saved mapping configurations for re-use across imports
model MappingTemplate {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  entity         String // EntityType: Product | Supplier | InventoryItem | Order
  mapping        Json // Record<string, string> canonical → source column
  attributeKeys  String[] // Extra column keys chosen for attributes storage

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
}

enum DataSourceType {
  CSV
  XLSX
}

enum ImportStatus {
  PENDING
  MAPPING
  PROCESSING
  COMPLETED
  FAILED
}

model Product {
  id                    String       @id @default(cuid())
  organizationId        String
  sku                   String
  name                  String
  description           String?
  category              String?
  unit                  String?
  unitCost              Decimal?     @db.Decimal(12, 4)
  active                Boolean      @default(true)
  externalId            String?
  attributes            Json? // Extra columns from import not in canonical schema
  metadata              Json?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  // Manufacturing canonical fields (merged)
  type                  ProductType?
  uom                   String       @default("")
  unitPrice             Decimal?
  leadTimeDays          Int?
  reorderPoint          Decimal?
  safetyStock           Decimal?
  isActive              Boolean      @default(true)
  deletedAt             DateTime?
  deactivatedAt         DateTime?    // Set when snapshot import deactivates this record
  deactivatedBySourceId String?      // DataSource.id that caused deactivation (for undo)
  // v2 additions
  makeBuy               MakeBuyType  @default(BUY)
  safetyStockConstraint Decimal?
  moq                   Int?
  orderMultiple         Int?
  // v3 canonical additions
  productFamily         String?
  shelfLifeDays         Int?
  drawingNumber         String?
  drawingRevision       String?
  abcClass              String?
  productLine           String?
  regulatoryClass       String?
  listPrice             Decimal?     @db.Decimal(12, 2)

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inventory       InventoryItem[]
  orderLines      OrderLine[]
  bomParent       BOMItem[]        @relation("BOMParent")
  bomChildren     BOMItem[]        @relation("BOMChild")
  lots            Lot[]
  bomHeaders      BOMHeader[]
  bomLines        BOMLine[]        @relation("BOMComponent")
  poLines         POLine[]
  soLines         SOLine[]
  workOrders      WorkOrder[]
  supplierItems   SupplierItem[]
  demandForecasts DemandForecast[]
  mpsEntries      MPSEntry[]
  routings        Routing[]        @relation("ProductRoutings")

  @@unique([organizationId, sku])
  @@index([organizationId])
}

model Supplier {
  id             String    @id @default(cuid())
  organizationId String
  code           String
  name           String
  email          String?
  phone          String?
  country        String?
  leadTimeDays   Int?
  paymentTerms   String?
  active         Boolean   @default(true)
  externalId     String?
  attributes     Json? // Extra columns from import not in canonical schema
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  // Manufacturing canonical fields (merged)
  contactName    String?
  address        String?
  currency       String?
  isActive       Boolean   @default(true)
  deletedAt      DateTime?
  deactivatedAt         DateTime?    // Set when snapshot import deactivates this record
  deactivatedBySourceId String?      // DataSource.id that caused deactivation (for undo)
  // v3 canonical additions
  city              String?
  leadTimeCategory  String?
  qualityRating     Decimal?  @db.Decimal(3, 1)
  onTimePct         Decimal?  @db.Decimal(5, 2)
  certifications    String?
  status            String?
  approvedSince     DateTime?

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orders         Order[]
  purchaseOrders PurchaseOrder[]
  supplierItems  SupplierItem[]

  @@unique([organizationId, code])
  @@index([organizationId])
}

model Location {
  id             String   @id @default(cuid())
  organizationId String
  code           String
  name           String
  type           String?
  parentId       String?
  active         Boolean  @default(true)
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  // Manufacturing canonical fields (merged)
  attributes     Json?
  isActive       Boolean  @default(true)
  deactivatedAt         DateTime?    // Set when snapshot import deactivates this record
  deactivatedBySourceId String?      // DataSource.id that caused deactivation (for undo)
  // v3 canonical additions
  city           String?
  countryCode    String?
  notes          String?

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent       Location?       @relation("LocationHierarchy", fields: [parentId], references: [id])
  children     Location[]      @relation("LocationHierarchy")
  inventory    InventoryItem[]
  equipment    Equipment[]

  @@unique([organizationId, code])
  @@index([organizationId])
}

model InventoryItem {
  id                 String    @id @default(cuid())
  organizationId     String
  productId          String
  locationId         String?
  quantity           Decimal   @db.Decimal(12, 4)
  reservedQty        Decimal   @default(0) @db.Decimal(12, 4)
  reorderPoint       Decimal?  @db.Decimal(12, 4)
  reorderQty         Decimal?  @db.Decimal(12, 4)
  attributes         Json? // Extra columns from import not in canonical schema
  updatedAt          DateTime  @updatedAt
  // Manufacturing canonical fields (merged)
  lotId              String?
  qtyOnHand          Decimal   @default(0)
  qtyAllocated       Decimal   @default(0)
  qtyAvailable       Decimal   @default(0)
  uom                String    @default("")
  // v2 additions
  qtyOnHold          Decimal   @default(0)
  qtyOnHandTotal     Decimal   @default(0)
  qtyOpenPO          Decimal   @default(0)
  qtyOnHandPlusPO    Decimal   @default(0)
  demandCurrentMonth Decimal?
  demandNextMonth    Decimal?
  demandMonth3       Decimal?
  demandPerDay       Decimal?
  daysOfSupply       Decimal?
  lastReceiptDate    DateTime?
  buyRecommendation  Boolean?
  recommendedQty     Decimal?
  moq                Int?
  orderMultiple      Int?
  leadTimeDays       Int?
  // v3 canonical additions
  unitCost           Decimal?  @db.Decimal(12, 4)
  totalValue         Decimal?  @db.Decimal(16, 2)
  // Outflow fields — raw counts from ERP
  outflow7d          Int?      // Units consumed/shipped in last 7 days
  outflow30d         Int?      // Units consumed/shipped in last 30 days
  outflow60d         Int?      // Units consumed/shipped in last 60 days
  outflow92d         Int?      // Units consumed/shipped in last 92 days

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id])
  location     Location?    @relation(fields: [locationId], references: [id])

  @@unique([organizationId, productId, locationId])
  @@index([organizationId])
}

model Order {
  id             String      @id @default(cuid())
  organizationId String
  orderNumber    String
  type           OrderType   @default(PURCHASE)
  supplierId     String?
  status         OrderStatus @default(PENDING)
  orderDate      DateTime?
  expectedDate   DateTime?
  totalAmount    Decimal?    @db.Decimal(12, 2)
  currency       String?
  notes          String?
  externalId     String?
  attributes     Json? // Extra columns from import not in canonical schema
  metadata       Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplier     Supplier?    @relation(fields: [supplierId], references: [id])
  lines        OrderLine[]

  @@unique([organizationId, orderNumber])
  @@index([organizationId])
}

enum OrderType {
  PURCHASE
  SALES
  TRANSFER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

model OrderLine {
  id         String   @id @default(cuid())
  orderId    String
  productId  String
  quantity   Decimal  @db.Decimal(12, 4)
  unitPrice  Decimal? @db.Decimal(12, 4)
  totalPrice Decimal? @db.Decimal(12, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model BOMItem {
  id          String   @id @default(cuid())
  parentId    String
  childId     String
  quantity    Decimal  @db.Decimal(12, 4)
  unit        String?
  scrapFactor Decimal? @db.Decimal(6, 4)
  attributes  Json?

  parent Product @relation("BOMParent", fields: [parentId], references: [id])
  child  Product @relation("BOMChild", fields: [childId], references: [id])

  @@unique([parentId, childId])
}

model ForecastEntry {
  id             String   @id @default(cuid())
  organizationId String
  sku            String
  period         String
  forecastQty    Decimal  @db.Decimal(12, 4)
  forecastUnit   String?
  channel        String?
  version        String?
  attributes     Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, sku, period, channel, version])
  @@index([organizationId])
  @@index([organizationId, sku])
}

model MpsEntry {
  id             String   @id @default(cuid())
  organizationId String
  sku            String
  period         String
  plannedQty     Decimal  @db.Decimal(12, 4)
  confirmedQty   Decimal? @db.Decimal(12, 4)
  workCenter     String?
  attributes     Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, sku, period, workCenter])
  @@index([organizationId])
  @@index([organizationId, sku])
}

model WorkOrder {
  id             String    @id @default(cuid())
  organizationId String
  orderNumber    String
  sku            String
  plannedQty     Decimal   @db.Decimal(12, 4)
  actualQty      Decimal?  @db.Decimal(12, 4)
  unit           String?
  workCenter     String?
  scheduledDate  DateTime?
  dueDate        DateTime?
  status         String    @default("PLANNED")
  attributes     Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  // Manufacturing canonical fields (merged)
  woNumber       String?
  productId      String?
  bomHeaderId    String?
  salesOrderId   String?
  qtyPlanned     Decimal   @default(0)
  qtyProduced    Decimal   @default(0)
  qtyScrapped    Decimal   @default(0)
  scheduledEnd   DateTime?
  actualStart    DateTime?
  actualEnd        DateTime?
  priority         Int?
  // v3 canonical additions
  routingId        String?
  productionLine   String?
  yieldPct         Decimal?  @db.Decimal(5, 2)
  lotNumber        String?
  operatorLeadId   String?

  organization  Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product       Product?             @relation(fields: [productId], references: [id])
  bomHeader     BOMHeader?           @relation(fields: [bomHeaderId], references: [id])
  salesOrder    SalesOrder?          @relation(fields: [salesOrderId], references: [id])
  operations    WorkOrderOperation[]
  batches       ProductionBatch[]
  qcInspections QCInspection[]

  @@unique([organizationId, orderNumber])
  @@index([organizationId])
  @@index([organizationId, sku])
}

model Routing {
  id             String   @id @default(cuid())
  organizationId String
  sku            String
  operationNo    Int
  workCenter     String
  description    String?
  setupTimeMins  Decimal? @db.Decimal(8, 2)
  runTimeMins    Decimal? @db.Decimal(8, 4)
  runTimeUnit    String?
  attributes     Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  // v2 canonical fields (merged — new canonical Routing header model)
  orgId          String?
  productId      String?
  revision       String?
  isActive       Boolean  @default(true)
  notes          String?
  // v3 canonical additions
  status         String?
  effectiveFrom  DateTime?
  effectiveTo    DateTime?
  approvedBy     String?
  approvalDate   DateTime?

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product?           @relation("ProductRoutings", fields: [productId], references: [id])
  operations   RoutingOperation[]

  @@unique([organizationId, sku, operationNo])
  @@index([organizationId])
  @@index([organizationId, sku])
}

model WorkCenter {
  id                    String   @id @default(cuid())
  organizationId        String
  code                  String
  name                  String
  description           String?
  availableHoursPerWeek Decimal? @db.Decimal(6, 2)
  efficiency            Decimal? @db.Decimal(5, 4)
  costRatePerHour       Decimal? @db.Decimal(10, 2)
  calendar              String?
  attributes            Json?
  isActive              Boolean  @default(true)
  deactivatedAt         DateTime?    // Set when snapshot import deactivates this record
  deactivatedBySourceId String?      // DataSource.id that caused deactivation (for undo)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  // v3 canonical additions
  department            String?
  capacityHrsDay        Decimal?  @db.Decimal(5, 2)
  operatorsPerShift     Int?
  shiftsPerDay          Int?
  availableDaysWeek     Int?
  oeeTargetPct          Decimal?  @db.Decimal(5, 2)
  oeeCurrentPct         Decimal?  @db.Decimal(5, 2)
  notes                 String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, code])
  @@index([organizationId])
}

// ============================================================
// LAYER 2 — OPERATIONAL BRAIN LAYER
// ============================================================

model BrainRule {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  description    String?
  category       RuleCategory
  entity         String
  condition      Json
  parameters     Json?
  status         RuleStatus   @default(DRAFT)
  currentVersion Int          @default(1)
  tags           String[]
  createdBy      String
  updatedBy      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  versions     BrainRuleVersion[]

  @@index([organizationId])
}

enum RuleCategory {
  THRESHOLD
  POLICY
  CONSTRAINT
  KPI
}

enum RuleStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model BrainRuleVersion {
  id            String   @id @default(cuid())
  ruleId        String
  version       Int
  snapshot      Json
  commitMessage String?
  committedBy   String
  committedAt   DateTime @default(now())

  rule BrainRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([ruleId, version])
}

// ============================================================
// LAYER 3 — APPLICATION LAYER
// ============================================================

model AppInstance {
  id             String      @id @default(cuid())
  organizationId String
  template       AppTemplate
  name           String
  description    String?
  config         Json        @default("{}")
  customCode     String?
  pinned         Boolean     @default(false)
  active         Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

enum AppTemplate {
  INVENTORY_COMMAND_CENTER
  PROCUREMENT_HUB
  DEMAND_FULFILLMENT
  DATA_CHAT
  CUSTOM_DASHBOARD
}

// ============================================================
// OPERATIONAL DATA ENVIRONMENT (ODE)
// ============================================================

// ----------------------------------------------------------
// Connectors — links to operational systems
// ----------------------------------------------------------

model Connector {
  id             String          @id @default(cuid())
  organizationId String
  name           String
  description    String?
  type           ConnectorType
  status         ConnectorStatus @default(INACTIVE)

  // Connection configuration: endpoints, auth, headers, field mappings, etc.
  config Json @default("{}")

  // Scheduling
  syncIntervalMs Int? // null = manual only
  lastSyncAt     DateTime?
  nextSyncAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  syncs        ConnectorSync[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

enum ConnectorType {
  FILE_IMPORT // CSV / XLSX uploads (wraps existing DataSource pipeline)
  REST_API // Pull from an external REST endpoint
  WEBHOOK // Receive pushed payloads from an external system
  DATABASE // Direct read from a remote Postgres / MySQL DB
  SFTP // Poll an SFTP share for new files
}

enum ConnectorStatus {
  ACTIVE
  INACTIVE
  SYNCING
  ERROR
}

model ConnectorSync {
  id          String     @id @default(cuid())
  connectorId String
  status      SyncStatus @default(PENDING)

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  recordsRead     Int @default(0)
  recordsUpserted Int @default(0)
  recordsFailed   Int @default(0)

  errors   Json? // Array of { row, message } error objects
  metadata Json? // Connector-specific diagnostics

  connector Connector @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  @@index([connectorId])
}

enum SyncStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  PARTIAL
}

// ----------------------------------------------------------
// Operational Graph — explicit relationship edges
// ----------------------------------------------------------

model OperationalRelationship {
  id             String @id @default(cuid())
  organizationId String

  type RelationshipType

  // Source node
  sourceType OdeEntityType
  sourceId   String

  // Target node
  targetType OdeEntityType
  targetId   String

  // Edge properties
  strength Float? // Optional weight / confidence (0–1)
  metadata Json? // e.g., { "leadTimeDays": 14, "unitCost": 9.99 }

  // Validity window (open-ended = currently active)
  validFrom DateTime  @default(now())
  validTo   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, type, sourceType, sourceId, targetType, targetId])
  @@index([organizationId, sourceType, sourceId])
  @@index([organizationId, targetType, targetId])
  @@index([organizationId, type])
}

// Relationship semantics
enum RelationshipType {
  SUPPLIES // Supplier → Product  (supplier provides this SKU)
  STOCKS_AT // Product  → Location (product is held at this location)
  SOURCES_FROM // Order    → Supplier (purchase order placed with supplier)
  FULFILLS // Order    → Product  (order line fulfils demand for this product)
  COMPONENT_OF // Product  → Product  (BOM: child is component of parent)
  LOCATED_IN // Location → Location (location is child of parent location)
  TRANSFERS_BETWEEN // Location → Location (transfer order moves stock between these)
  SHIPS_TO // Supplier → Location (supplier delivers to this location)
}

// Which canonical entity types participate in the graph
enum OdeEntityType {
  PRODUCT
  SUPPLIER
  LOCATION
  INVENTORY_ITEM
  ORDER
  ORDER_LINE
}

// ============================================================
// MANUFACTURING CANONICAL ENUMS
// ============================================================

enum ProductType {
  FINISHED_GOOD
  RAW_MATERIAL
  COMPONENT
  SUBASSEMBLY
  SERVICE
}

enum LocationType {
  WAREHOUSE
  AREA
  AISLE
  BIN
  EXTERNAL
}

enum MovementType {
  RECEIPT
  ISSUE
  TRANSFER
  ADJUSTMENT
  RETURN
  SCRAP
}

enum POStatus {
  DRAFT
  SENT
  CONFIRMED
  PARTIAL
  RECEIVED
  CANCELLED
}

enum WOStatus {
  PLANNED
  RELEASED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum OpStatus {
  PENDING
  IN_PROGRESS
  DONE
  SKIPPED
}

enum SOStatus {
  DRAFT
  CONFIRMED
  IN_PRODUCTION
  SHIPPED
  DELIVERED
  CANCELLED
}

enum QCType {
  INCOMING
  IN_PROCESS
  FINAL
  PERIODIC
}

enum QCStatus {
  PENDING
  PASS
  FAIL
  CONDITIONAL_PASS
}

enum EquipmentStatus {
  OPERATIONAL
  MAINTENANCE
  DOWN
  RETIRED
}

enum MaintenanceType {
  PREVENTIVE
  CORRECTIVE
  PREDICTIVE
  INSPECTION
}

// ----------------------------------------------------------
// Operational Events — immutable state-change log
// ----------------------------------------------------------

model OperationalEvent {
  id             String @id @default(cuid())
  organizationId String

  entityType OdeEntityType
  entityId   String

  // e.g. "inventory.quantity_changed", "order.status_changed", "product.created"
  eventType String

  previousState Json? // Snapshot before the change
  currentState  Json // Snapshot after the change

  // Which connector/system triggered this event
  connectorId String?
  source      String? // Human-readable source label

  occurredAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, entityType, entityId])
  @@index([organizationId, occurredAt])
  @@index([organizationId, eventType])
}

