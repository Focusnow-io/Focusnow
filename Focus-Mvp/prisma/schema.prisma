// ============================================================
// NORMALIZATION LAYER
// ============================================================

enum ResolutionStatus {
  PENDING // 70–90% confidence — awaiting human review
  AUTO_MERGED // >90% confidence — merged automatically
  REVIEWED_MERGED // Human confirmed merge
  REVIEWED_KEPT // Human decided to keep as separate entity
  NO_MATCH // No candidate above 70% threshold
}

// Records every entity deduplication decision made during import.
// matchFields stores both similarity scores and (for auto-merges)
// the dry-run FK change plan for full auditability.
model EntityResolutionLog {
  id             String           @id @default(cuid())
  organizationId String
  entityType     String // "Product" | "Supplier" | "Location" | "Customer"
  incomingId     String // ID of the newly imported entity
  matchedId      String? // ID of the existing canonical entity
  confidence     Float // 0–100
  status         ResolutionStatus @default(PENDING)
  matchFields    Json? // [{field, incomingVal, matchedVal, score}, ...fkChanges]
  resolvedAt     DateTime?
  resolvedBy     String? // userId of human reviewer
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, entityType, status])
  @@index([organizationId, incomingId])
}

// One row per org — always overwritten with the latest completeness snapshot.
model ModelCompletenessReport {
  id                String   @id @default(cuid())
  organizationId    String   @unique
  generatedAt       DateTime @default(now())
  entityCounts      Json // { Product: 42, Supplier: 5, ... }
  capabilities      Json // { demand_forecasting: { unlocked, coverage, qualityGates, missing[] }, ... }
  overallScore      Float // 0–100 weighted average across capability coverage scores
  consistencyIssues Json? // ConsistencyIssue[] — orphaned FKs, broken cross-entity links
  updatedAt         DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// One row per org per entity type — tracks when each data type was last imported and whether it's stale.
model ModelFreshness {
  id             String   @id @default(cuid())
  organizationId String
  entityType     String
  lastImportedAt DateTime
  recordCount    Int
  staleDays      Int // days since lastImportedAt (recomputed each check)
  isStale        Boolean // staleDays > threshold for this entityType
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, entityType])
  @@index([organizationId])
}

// ============================================================
// LOGIC PARAMS
// ============================================================

enum LogicParamStatus {
  IMPORTED
  CONFIRMED
}

model LogicParam {
  id             String           @id @default(cuid())
  organizationId String
  key            String
  value          Json
  sourceColumn   String?
  status         LogicParamStatus @default(IMPORTED)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@index([organizationId])
}

// ============================================================
// FLAGGED COLUMNS
// ============================================================

// Columns that users flagged as "not in the registry" during import.
// Platform team reviews these to inform registry additions.
model FlaggedColumn {
  id             String   @id @default(cuid())
  organizationId String
  entityType     String
  columnName     String // the original column header from their file
  sampleValues   Json // array of up to 5 sample values
  flaggedAt      DateTime @default(now())
  status         String   @default("pending") // pending | added | rejected

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([entityType, status])
}

