  lotNumber        String? // TODO: relation to lot
  inspectionId     String? // TODO: relation to qc_inspection
  qtyAffected      Decimal?
  description      String
  rootCause        String?
  disposition      String?
  correctiveAction String?
  responsibleId    String? // TODO: relation to employee
  dueDate          DateTime?    @db.Date
  closedDate       DateTime?    @db.Date
  status           NcrStatus
  severity         NcrSeverity?

  @@map("ncr")
}

model Capa {
  capaId                String                  @id
  type                  CapaType
  source                CapaSource?
  sourceReference       String?
  dateOpened            DateTime                @db.Date
  title                 String
  description           String
  rootCauseCategory     String?
  rootCauseDetail       String?
  actionPlan            String?
  actionOwnerId         String? // TODO: relation to employee
  targetCloseDate       DateTime?               @db.Date
  actualCloseDate       DateTime?               @db.Date
  verificationMethod    String?
  verificationDate      DateTime?               @db.Date
  verificationResult    CapaVerificationResult?
  effectivenessCheckDue DateTime?               @db.Date
  effectivenessResult   String?
  status                CapaStatus
  priority              String?
  notes                 String?

  @@map("capa")
}

// ============================================================
// AI CHAT
// ============================================================

model Conversation {
  id           String   @id @default(cuid())
  orgId        String
  userId       String
  title        String
  messageCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  projectId String?
  project   ChatProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  messages ConversationMessage[]

  @@index([orgId, userId])
  @@index([projectId])
}

model ChatProject {
  id        String   @id @default(cuid())
  orgId     String
  userId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversations Conversation[]

  @@index([orgId, userId])
}

model ConversationMessage {
  id             String      @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String
  toolCalls      Json?
  tokensUsed     Int?
  model          String?
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

enum MessageRole {
  USER
  ASSISTANT
  TOOL_RESULT
}

model ChatUsage {
  id                  String   @id @default(cuid())
  orgId               String
  userId              String
  date                DateTime @db.Date
  messageCount        Int      @default(0)
  estimatedTokensUsed Int      @default(0)

  @@unique([orgId, userId, date])
}

model TokenUsage {
  id               String   @id @default(cuid())
  orgId            String
  userId           String
  date             DateTime @db.Date
  feature          String   @default("chat")
  inputTokens      Int      @default(0)
  outputTokens     Int      @default(0)
  cacheReadTokens  Int      @default(0)
  cacheWriteTokens Int      @default(0)
  requestCount     Int      @default(0)

  @@unique([orgId, userId, date, feature])
  @@index([orgId, date])
  @@index([userId, date])
}
