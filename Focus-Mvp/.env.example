# Database
# For Supabase: use the Pooler (Session mode) URL here
DATABASE_URL=postgresql://postgres:password@localhost:5432/focus

# For Supabase migrations only (direct connection, bypasses PgBouncer).
# Set this locally when running: prisma migrate deploy
# Do NOT add this to Vercel env vars.
# DIRECT_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# NextAuth
NEXTAUTH_SECRET=your-secret-here-generate-with-openssl-rand-hex-32
NEXTAUTH_URL=http://localhost:3000

# Email — Resend (https://resend.com, free tier: 100 emails/day)
# 1. Sign up at resend.com → Dashboard → API Keys → Create API Key
# 2. Paste the key below (starts with re_)
RESEND_API_KEY=re_your_api_key_here

# Sender address shown on emails.
# Without a verified domain, use: onboarding@resend.dev  (sends to your Resend account email only)
# With a verified domain, use:    Focus <noreply@yourdomain.com>
EMAIL_FROM=Focus <onboarding@resend.dev>

# Anthropic (required for Data Chat app)
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here
